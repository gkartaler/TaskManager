<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mein Task Manager" Height="650" Width="760">

    <Grid Margin="10">

        <!-- 5 Zeilen von oben nach unten -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zeile 0: Überschrift -->
        <TextBlock Grid.Row="0" Text="Mein Task Manager" FontSize="22" FontWeight="Bold"/>

        <!-- Zeile 1: Eingabe -->
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBox x:Name="TitelEingabe" Width="270"/>

            <ComboBox x:Name="PrioritaetAuswahl" Width="90">
                <ComboBoxItem Content="Hoch"/>
                <ComboBoxItem Content="Mittel" IsSelected="True"/>
                <ComboBoxItem Content="Niedrig"/>
            </ComboBox>

            <DatePicker x:Name="DatumAuswahl" Width="140"/>

            <Button x:Name="HinzufuegenKnopf" Content="Hinzufügen"
                    Click="HinzufuegenKnopf_Click"/>
        </StackPanel>

        <!-- Zeile 2: Filter + Sortieren -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Anzeigen:" VerticalAlignment="Center"/>

            <ComboBox x:Name="FilterAuswahl" Width="100"
                      SelectionChanged="FilterAuswahl_SelectionChanged">
                <ComboBoxItem Content="Alle" IsSelected="True"/>
                <ComboBoxItem Content="Offen"/>
                <ComboBoxItem Content="Erledigt"/>
            </ComboBox>

            <Button x:Name="SortierenKnopf" Content="Nach Priorität sortieren"
                    Click="SortierenKnopf_Click"/>
        </StackPanel>

        <!-- Zeile 3: die Liste -->
        <ListBox x:Name="AufgabenListe" Grid.Row="3" FontFamily="Consolas" FontSize="14"/>

        <!-- Zeile 4: Knöpfe unten + Zähler -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button x:Name="ErledigtKnopf" Content="Erledigt / Offen"
                    Click="ErledigtKnopf_Click"/>

            <Button x:Name="BearbeitenKnopf" Content="Bearbeiten"
                    Click="BearbeitenKnopf_Click"/>

            <Button x:Name="LoeschenKnopf" Content="Löschen"
                    Click="LoeschenKnopf_Click"/>

            <TextBlock x:Name="ZaehlerText" Text="0 von 0 Aufgaben erledigt"
                       VerticalAlignment="Center"/>
        </StackPanel>

    </Grid>
</Window>